{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["typescript", "react", "react-perf", "unicorn", "jsdoc", "promise"],
    "categories": {
        "correctness": "error",
        "suspicious": "error",
        "perf": "warn",
        "pedantic": "off",
        "restriction": "off",
        "style": "off"
    },
    "rules": {
        "react/react-in-jsx-scope": "off",
        "react/style-prop-object": "off",
        "no-debugger": "error",
        "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
        "no-var": "error",
        "prefer-const": "error",
        "eqeqeq": ["error", "always"],
        "react-perf/jsx-no-new-object-as-prop": "off",
        "react-perf/jsx-no-new-array-as-prop": "off",
        "react-perf/jsx-no-new-function-as-prop": "off"
    },
    "ignorePatterns": [
        "node_modules",
        ".expo",
        "dist",
        "coverage",
        "ios",
        "android",
        "*.config.js",
        "*.config.mjs",
        "scripts/**"
    ]
}
