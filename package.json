{
    "name": "template-rn",
    "version": "0.1.0",
    "private": true,
    "main": "expo-router/entry",
    "engines": {
        "node": ">=24.0.0"
    },
    "scripts": {
        "start": "expo start",
        "start:clear": "expo start --clear",
        "ios": "expo start --ios",
        "android": "expo start --android",
        "prebuild": "expo prebuild --clean",
        "prebuild:preview": "APP_VARIANT=preview expo prebuild --clean",
        "doctor": "expo-doctor",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "lint:oxlint": "oxlint --config .oxlintrc.json src",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "verify": "npm run typecheck && npm run lint:oxlint && npm run lint && npm run format:check && npm run test:coverage",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "bundle:analyze": "EXPO_ATLAS=1 expo export --platform ios --output-dir .atlas",
        "perf:capture": "node scripts/capture-bundle-metrics.mjs --export",
        "perf:measure": "node scripts/capture-bundle-metrics.mjs",
        "perf:baseline": "node scripts/capture-bundle-metrics.mjs --export --write-baseline",
        "perf:check": "node scripts/capture-bundle-metrics.mjs --export --check",
        "ci:local": "npm run typecheck && npm run lint:oxlint && npm run lint && npm run format:check && npm run test:coverage && npm run doctor",
        "prepare": "husky"
    },
    "dependencies": {
        "@expo/vector-icons": "^15.0.2",
        "@react-native-async-storage/async-storage": "^2.2.0",
        "@t3-oss/env-core": "^0.13.11",
        "@tanstack/react-query": "^5.99.2",
        "babel-preset-expo": "~55.0.8",
        "clsx": "^2.1.1",
        "expo": "~55.0.0",
        "expo-application": "~55.0.14",
        "expo-constants": "~55.0.14",
        "expo-device": "~55.0.15",
        "expo-font": "~55.0.6",
        "expo-linking": "~55.0.13",
        "expo-localization": "~55.0.13",
        "expo-modules-core": "~55.0.22",
        "expo-router": "~55.0.12",
        "expo-secure-store": "~55.0.13",
        "expo-splash-screen": "~55.0.18",
        "expo-status-bar": "~55.0.5",
        "expo-system-ui": "~55.0.15",
        "expo-updates": "~55.0.20",
        "i18next": "^26.0.6",
        "nativewind": "^4.2.3",
        "react": "19.2.0",
        "react-hook-form": "^7.71.1",
        "react-i18next": "^17.0.4",
        "react-native": "0.83.4",
        "react-native-edge-to-edge": "^1.8.1",
        "react-native-gesture-handler": "~2.30.0",
        "react-native-reanimated": "4.2.1",
        "react-native-safe-area-context": "~5.6.2",
        "react-native-screens": "~4.23.0",
        "react-native-svg": "15.15.3",
        "react-native-worklets": "0.7.4",
        "zod": "^4.3.6",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@babel/core": "^7.29.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^9.39.1",
        "@hookform/resolvers": "^5.2.2",
        "@tanstack/eslint-plugin-query": "^5.99.2",
        "@testing-library/react-native": "^13.3.3",
        "@types/jest": "^29.5.14",
        "@types/react": "~19.2.10",
        "babel-plugin-transform-remove-console": "^6.9.4",
        "eslint": "^9.39.4",
        "eslint-config-expo": "~55.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-i18next": "^6.1.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-jest": "^29.15.2",
        "eslint-plugin-oxlint": "^1.60.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react-compiler": "^19.1.0-rc.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "expo-atlas": "^0.4.3",
        "expo-doctor": "^1.18.18",
        "husky": "^9.1.7",
        "jest": "~29.7.0",
        "jest-expo": "~55.0.16",
        "lint-staged": "^16.4.0",
        "oxlint": "^1.60.0",
        "prettier": "^3.8.3",
        "react-test-renderer": "19.2.0",
        "tailwindcss": "^3.4.17",
        "typescript": "~5.9.0",
        "typescript-eslint": "^8.58.2"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "oxlint --config .oxlintrc.json --fix",
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,md,yml,yaml}": [
            "prettier --write"
        ]
    },
    "jest": {
        "preset": "jest-expo",
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/src/$1"
        },
        "setupFilesAfterEnv": [
            "<rootDir>/src/test/setup.ts"
        ],
        "collectCoverageFrom": [
            "src/**/*.{ts,tsx}",
            "!src/**/*.d.ts",
            "!src/**/index.ts",
            "!src/test/**",
            "!src/app/**",
            "!src/env.ts",
            "!src/shared/lib/constants/**",
            "!src/shared/lib/i18n/**",
            "!src/shared/locales/**",
            "!src/**/*.stories.{ts,tsx}"
        ],
        "coverageThreshold": {
            "global": {
                "statements": 60,
                "branches": 10,
                "functions": 60,
                "lines": 60
            }
        },
        "transformIgnorePatterns": [
            "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|nativewind|react-native-css-interop|react-native-reanimated|react-native-worklets))"
        ]
    },
    "overrides": {
        "react-dom": "19.2.0"
    },
    "expo": {
        "install": {
            "exclude": [
                "react-native-worklets"
            ]
        }
    }
}
