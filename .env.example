# Public env — exposed to the app bundle. Never put secrets here.
# Validated at startup: `import { env } from '@/env'` (Zod + @t3-oss/env-core).

EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_ENV=development

# Optional: EAS Build / Update injects `EAS_PROJECT_ID` in cloud builds.
# For local `eas build`, add to eas.json → build.*.env or export in CI.
