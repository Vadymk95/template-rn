{
    "cli": {
        "version": ">= 16.0.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "env": {
                "APP_VARIANT": "development"
            },
            "ios": {
                "resourceClass": "m-medium",
                "simulator": true
            },
            "android": {
                "buildType": "apk"
            }
        },
        "preview": {
            "distribution": "internal",
            "channel": "preview",
            "env": {
                "APP_VARIANT": "preview"
            },
            "ios": {
                "resourceClass": "m-medium",
                "simulator": false
            },
            "android": {
                "buildType": "apk"
            }
        },
        "production": {
            "autoIncrement": true,
            "channel": "production",
            "env": {
                "APP_VARIANT": "production"
            },
            "ios": {
                "resourceClass": "m-medium"
            }
        }
    },
    "submit": {
        "production": {}
    }
}
