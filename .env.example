# Public env — exposed to the app bundle. Never put secrets here.
# Access via `import { env } from '@/shared/config/env'` (validated by Zod at startup).

EXPO_PUBLIC_API_URL=https://api.example.com
EXPO_PUBLIC_API_TIMEOUT_MS=15000
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_PERF_MARKS=false
